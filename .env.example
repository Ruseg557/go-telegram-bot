# Telegram Bot Token (получите у @BotFather)
# Пример: 1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Путь к модели Whisper (относительный или абсолютный)
WHISPER_MODEL_PATH=models/ggml-base.bin # Или ggml-meduim.bin
WHISPER_EXECUTABLE=C:/whisper.cpp/build/bin/Release/whisper-cli.exe # Или иной путь, где установлен whisper.cpp

# Режим отладки (true/false)
DEBUG_MODE=true